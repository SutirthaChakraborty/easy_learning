# Server Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of the React frontend (used to whitelist CORS requests)
CLIENT_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Uncomment and fill in when you add a database driver to src/config/db.js
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=easy_learn
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# MONGO_URI=mongodb://localhost:27017/easy_learn
